{
  "name": "casuya-api",
  "version": "1.0.0",
  "private": true,
  "description": "Reception Desk - Gateway to the entire Casuya ecosystem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "dev": "tsc && node dist/server.js",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["casuya", "api", "gateway", "rest", "graphql", "websocket"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "apollo-server-express": "^3.13.0",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "ws": "^8.16.0",
    "zod": "^3.22.4",
    "uuid": "^9.0.0",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/semver": "^7.5.6",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
